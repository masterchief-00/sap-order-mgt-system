{
  "name": "sap-order-mgt-system",
  "version": "1.0.0",
  "description": "Welcome to your new CAP project.",
  "homepage": "https://github.com/masterchief-00/sap-order-mgt-system#readme",
  "bugs": {
    "url": "https://github.com/masterchief-00/sap-order-mgt-system/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/masterchief-00/sap-order-mgt-system.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "cds-serve",
    "test": "cross-env cds_env_profiles=test jest",
    "test:coverage": "jest --coverage",
    "watch-products": "cds watch --open ns.products/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-customer": "cds watch --open ns.customer/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-orders": "cds watch --open ns.orders/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "jest": {
    "testEnvironment": "node"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db/oms.db"
        }
      },
      "[test]": {
        "db": {
          "kind": "sqlite",
          "credentials": {
            "url": ":memory:"
          }
        }
      }
    }
  },
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap-cloud-sdk/connectivity": "^4.7.0",
    "@sap-cloud-sdk/http-client": "^4.7.0",
    "@sap-cloud-sdk/resilience": "^4.7.0",
    "@sap/cds": "^9.9.1",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1",
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9.9.2",
    "cds-plugin-ui5": "^0.13.6",
    "cross-env": "^10.1.0",
    "cross-fetch": "^4.1.0",
    "jest": "^30.4.2",
    "sqlite3": "^6.0.1"
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/products",
    "app/customer",
    "app/orders"
  ]
}
